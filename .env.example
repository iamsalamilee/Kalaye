# Ghost Sync — Environment Variables
# Copy this to .env and fill in your keys

# Whisper Model (default: 'base', options: tiny, base, small, medium, large-v3)
# 'base' = 150MB, good accuracy, ~10 min per movie on CPU
# 'small' = 500MB, great accuracy, ~20 min per movie on CPU
WHISPER_MODEL=base

# Gemini API (for subtitle translation — coming soon)
# Get yours at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_api_key_here
